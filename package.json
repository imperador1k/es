{
  "name": "escolaa",
  "main": "expo-router/entry",
  "version": "1.0.4",
  "author": "Imperador1k",
  "description": "A melhor plataforma escolar do mundo",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:web": "npx expo export -p web",
    "electron:dev": "npm run build:web && node copy-fonts.js && electron electron/main.js",
    "electron:build": "npx dotenv-cli -- cmd /c \"npm run build:web && node copy-fonts.js && electron-builder --win --publish always\""
  },
  "dependencies": {
    "@config-plugins/react-native-callkeep": "^12.0.0",
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo/metro-runtime": "~6.1.2",
    "@expo/vector-icons": "^15.0.3",
    "@hookform/resolvers": "^5.2.2",
    "@livekit/components-react": "^2.9.17",
    "@livekit/components-styles": "^1.2.0",
    "@livekit/react-native": "^2.9.6",
    "@livekit/react-native-webrtc": "^137.0.2",
    "@notifee/react-native": "^9.1.8",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-native-community/netinfo": "11.4.1",
    "@react-native-community/slider": "5.0.1",
    "@react-navigation/native": "^7.1.8",
    "@supabase/supabase-js": "^2.89.0",
    "@tanstack/query-async-storage-persister": "^5.90.14",
    "@tanstack/react-query": "^5.90.16",
    "@tanstack/react-query-persist-client": "^5.90.14",
    "@types/proj4": "^2.5.6",
    "base64-arraybuffer": "^1.0.2",
    "csv-parse": "^6.1.0",
    "date-fns": "^4.1.0",
    "electron-serve": "^3.0.0",
    "electron-updater": "^6.8.3",
    "expo": "~54.0.30",
    "expo-auth-session": "~7.0.10",
    "expo-av": "~16.0.8",
    "expo-blur": "~15.0.8",
    "expo-build-properties": "~1.0.10",
    "expo-calendar": "~15.0.8",
    "expo-camera": "~17.0.10",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.12",
    "expo-crypto": "~15.0.8",
    "expo-dev-client": "~6.0.20",
    "expo-device": "~8.0.10",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.10",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-intent-launcher": "~13.0.8",
    "expo-keep-awake": "~15.0.8",
    "expo-linear-gradient": "^15.0.8",
    "expo-linking": "~8.0.11",
    "expo-location": "~19.0.8",
    "expo-network": "~8.0.8",
    "expo-notifications": "~0.32.15",
    "expo-router": "~6.0.21",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.16",
    "expo-web-browser": "~15.0.10",
    "livekit-client": "^2.16.1",
    "nativewind": "^4.2.1",
    "proj4": "^2.20.8",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.69.0",
    "react-native": "0.81.5",
    "react-native-calendars": "^1.1313.0",
    "react-native-callkeep": "^4.3.16",
    "react-native-confetti-cannon": "^1.5.2",
    "react-native-copilot": "^3.3.3",
    "react-native-gesture-handler": "^2.30.0",
    "react-native-gifted-charts": "^1.4.70",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-markdown-display": "^7.0.2",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "^15.15.1",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "0.5.1",
    "tailwindcss": "^3.4.19",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "electron": "^39.2.7",
    "electron-builder": "^26.4.0",
    "react-test-renderer": "19.1.0",
    "supabase": "^2.70.5",
    "typescript": "~5.9.2"
  },
  "browser": {
    "react-native-reanimated": "./lib/reanimated.web.ts"
  },
  "private": true,
  "build": {
    "appId": "com.escolaa.desktop",
    "productName": "Escola+",
    "directories": {
      "output": "electron-build"
    },
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "files": [
      "dist/**/*",
      "electron/main.js",
      "electron/preload.js",
      "node_modules/**/*",
      "!node_modules/expo{,-*}/**/*",
      "!node_modules/@expo/**/*",
      "!node_modules/react{,-*}/**/*",
      "!node_modules/@react*/**/*",
      "!node_modules/tailwindcss/**/*",
      "!node_modules/lucide-react/**/*",
      "!node_modules/@livekit/**/*",
      "!node_modules/livekit-client/**/*",
      "!node_modules/typescript/**/*",
      "!node_modules/@types/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/images/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/images/icon.ico",
      "uninstallerIcon": "assets/images/icon.ico"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "imperador1k",
        "repo": "es"
      }
    ],
    "protocols": [
      {
        "name": "escolaa",
        "schemes": [
          "escolaa"
        ]
      }
    ]
  }
}
