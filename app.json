{
  "expo": {
    "name": "escolaa",
    "slug": "escolaa",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "escolaa",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "A app precisa da câmara para ler QR Codes de amigos e enviar fotos.",
        "NSCalendarsUsageDescription": "A Escolaa precisa de aceder ao teu calendário para sincronizar as tuas aulas e eventos pessoais.",
        "NSRemindersUsageDescription": "A Escolaa precisa de acesso para criar lembretes de estudo.",
        "UIBackgroundModes": [
          "audio",
          "voip",
          "fetch",
          "remote-notification"
        ]
      }
    },
    "android": {
      "package": "com.imperador1k.escolaa",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.VIBRATE",
        "READ_CALENDAR",
        "WRITE_CALENDAR",
        "android.permission.READ_PHONE_STATE",
        "android.permission.CALL_PHONE",
        "android.permission.MANAGE_OWN_CALLS",
        "android.permission.BIND_TELECOM_CONNECTION_SERVICE",
        "android.permission.FOREGROUND_SERVICE_PHONE_CALL"
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "A app precisa da câmara para ler QR Codes de amigos e enviar fotos.",
          "microphonePermission": "A app precisa do microfone para gravar vídeos e chamadas."
        }
      ],
      [
        "expo-calendar",
        {
          "calendarPermission": "A Escolaa precisa de aceder ao teu calendário para sincronizar as tuas aulas e eventos pessoais."
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-font",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.1"
          },
          "android": {
            "minSdkVersion": 24
          }
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "A app precisa do microfone para chamadas de voz nas Study Rooms."
        }
      ],
      "@config-plugins/react-native-callkeep"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e79f12d2-9b7a-4e9b-99b0-c876e9c3a3c0"
      }
    }
  }
}